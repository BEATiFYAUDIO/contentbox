{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/check-prisma-provider.js && tsx watch src/server.ts",
    "start:api": "node ../../scripts/check-prisma-provider.js && tsx src/server.ts",
    "runtime:supervisor": "tsx src/runtime/supervisor.ts",
    "whoami": "node dev/whoami.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:check": "prisma validate && prisma generate",
    "prisma:seed": "prisma db seed",
    "upgrade:advanced": "powershell -NoProfile -ExecutionPolicy Bypass -File ./upgrade-advanced.ps1",
    "smoke:basic": "npx tsx src/scripts/smoke_basic_mode.ts",
    "smoke:advanced": "npx tsx src/scripts/smoke_advanced_mode.ts",
    "test:storefront-gating": "API_BASE_URL=http://127.0.0.1:4000 DEV_ALLOW_SIMULATE_PAYMENTS=1 npx tsx src/scripts/storefront_gating_test.ts",
    "test:delegated-invoice-harness": "npx tsx src/payments/delegated_invoice_harness.ts",
    "test:delegated-invoice-harness:ci": "EXPECT_SETTLED=1 EXPECT_UI_CONSISTENT=1 npx tsx src/payments/delegated_invoice_harness.ts",
    "test:identity-gating": "API_BASE_URL=http://127.0.0.1:4000 npx tsx src/scripts/identity_gating_test.ts",
    "test:participant-payout-phase2": "API_BASE_URL=http://127.0.0.1:4000 npx tsx src/payments/participant_payout_phase2.test.ts",
    "test:buyer-auth": "API_BASE_URL=http://127.0.0.1:4000 npx tsx src/scripts/buyer_auth_test.ts",
    "test:lightning-onboarding": "npx tsx --test src/payments/lightning.onboarding.test.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^6.9.0",
    "bcrypt": "^6.0.0",
    "bip32": "^4.0.0",
    "bitcoinjs-lib": "^6.1.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "ethers": "^6.9.0",
    "fastify": "^5.7.2",
    "nodemailer": "^6.9.15",
    "nostr-tools": "^2.23.3",
    "pg": "^8.17.2",
    "tiny-secp256k1": "^2.2.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.1.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
