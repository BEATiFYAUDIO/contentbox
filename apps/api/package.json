{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/check-prisma-provider.js && tsx watch src/server.ts",
    "start:api": "node ../../scripts/check-prisma-provider.js && tsx src/server.ts",
    "whoami": "node dev/whoami.mjs",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:check": "prisma validate && prisma generate",
    "prisma:seed": "prisma db seed",
    "upgrade:advanced": "powershell -NoProfile -ExecutionPolicy Bypass -File ./upgrade-advanced.ps1",
    "test": "npm run smoke:mode && npm run test:lightning-onboarding",
    "smoke:mode": "tsx src/scripts/node_mode_test.ts",
    "smoke:basic": "npm run smoke:mode",
    "smoke:public-host": "cross-env API_BASE_URL=http://127.0.0.1:4000 tsx src/public_host_smoke.ts",
    "test:storefront-gating": "cross-env API_BASE_URL=http://127.0.0.1:4000 DEV_ALLOW_SIMULATE_PAYMENTS=1 tsx src/scripts/storefront_gating_test.ts",
    "test:delegated-invoice-harness": "npx tsx src/payments/delegated_invoice_harness.ts",
    "test:delegated-invoice-harness:ci": "cross-env EXPECT_SETTLED=1 EXPECT_UI_CONSISTENT=1 tsx src/payments/delegated_invoice_harness.ts",
    "test:identity-gating": "cross-env API_BASE_URL=http://127.0.0.1:4000 tsx src/scripts/identity_gating_test.ts",
    "test:product-tier-gating": "cross-env API_BASE_URL=http://127.0.0.1:4000 tsx src/scripts/product_tier_gating_test.ts",
    "test:smoke-invite-split": "npx tsx src/scripts/smoke_invite_split_flow.ts",
    "test:participant-payout-phase2": "cross-env API_BASE_URL=http://127.0.0.1:4000 tsx src/payments/participant_payout_phase2.test.ts",
    "test:lightning-onboarding": "npx tsx --test src/payments/lightning.onboarding.test.ts",
    "test:derivative-accounting-regression": "cross-env API_BASE_URL=http://127.0.0.1:4000 tsx src/scripts/derivative_accounting_regression_checks.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^6.9.0",
    "bcrypt": "^6.0.0",
    "bip32": "^4.0.0",
    "bitcoinjs-lib": "^6.1.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.4.5",
    "ethers": "^6.9.0",
    "fastify": "^5.7.2",
    "nodemailer": "^6.9.15",
    "nostr-tools": "^2.23.3",
    "pg": "^8.17.2",
    "tiny-secp256k1": "^2.2.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.1.0",
    "cross-env": "^10.1.0",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
