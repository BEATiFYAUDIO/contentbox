{
  "name": "certifyd-workspace",
  "private": true,
  "scripts": {
    "dev:dashboard": "npm --prefix apps/dashboard run dev",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:api:safe": "bash ./scripts/dev-api.sh",
    "dev:api:safe:win": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/dev-api.ps1",
    "dev:node": "npm --prefix apps/dashboard run build && npm --prefix apps/api run dev"
  }
}
